# Copy this file to .env and fill in your values.

PORT=5001
NODE_ENV=development

# MongoDB — local or Atlas (mongodb+srv://user:pass@cluster.mongodb.net/dbname)
MONGODB_URI=mongodb://127.0.0.1:27017/wanderlux

# JWT secret — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string_minimum_32_chars

# Razorpay credentials
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Cloudinary (admin image uploads — folder optional, default wanderlux/destinations)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# CLOUDINARY_UPLOAD_FOLDER=wanderlux/destinations

# One-time admin bootstrap (run: npm run seed:admin)
ADMIN_EMAIL=admin@wanderluxtravel.com
ADMIN_PASSWORD=change_this_admin_password
ADMIN_NAME=WanderLux Admin

# Comma-separated origins for CORS (browser frontend URLs)
# Add your Netlify/Vercel/Pages URL after deploying the static frontend, e.g.:
#   https://tourmatrix.netlify.app,https://your-name.vercel.app
# Local dev:
#   http://127.0.0.1:5500,http://localhost:5500
# Leave empty or * to allow all (development only — not for production)
CORS_ORIGIN=http://127.0.0.1,http://localhost,http://127.0.0.1:5500,http://localhost:5500
